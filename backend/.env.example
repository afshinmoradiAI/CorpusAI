ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
MAX_TOKENS_PER_PAPER=100000
# Comma-separated list. Add the production frontend URL once you have it.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Set a long random string in production. If empty, auth is bypassed (dev only).
APP_API_KEY=
RATE_LIMIT_PER_MINUTE=10
ENVIRONMENT=development

# Token budget per Explore/Write run (workflow aborts if exceeded)
MAX_TOKENS_PER_REQUEST=2000000
# Number of recent results held in memory (per pipeline)
RESULT_CACHE_SIZE=64
# Cache Anthropic system prompts (Anthropic prompt caching)
ENABLE_PROMPT_CACHE=true

# Where the SQLite reference database lives. On Fly, point this at a volume mount.
DATA_DIR=./data
